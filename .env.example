# ============================================
# JIRA CREDENTIALS
# ============================================
JIRA_USERNAME=your_username
JIRA_PASSWORD=your_password
JIRA_BASE_URL=https://jira.bni.co.id

# ============================================
# JIRA QUERY PARAMETERS
# ============================================
# Version name from JIRA (exact match, case-sensitive)
JIRA_VERSION_NAME=Regression R5.2

# Cycle name from JIRA (exact match, case-sensitive)
JIRA_CYCLE_NAME=Feature R2

# Folder name from JIRA (exact match, case-sensitive)
JIRA_FOLDER_NAME=Profile and Settings - Android

# ============================================
# OUTPUT CONFIGURATION
# ============================================
# Optional: Custom Output Folder (default: yml-ts/ and yml-tc/)
# If not set, output will be in yml-ts/ and yml-tc/
# If set, output will be in {OUTPUT_FOLDER}/yml-ts/ and {OUTPUT_FOLDER}/yml-tc/
# 
# Examples:
# OUTPUT_FOLDER=profilesettings  → profilesettings/yml-ts/ and profilesettings/yml-tc/
# OUTPUT_FOLDER=transfer         → transfer/yml-ts/ and transfer/yml-tc/
# OUTPUT_FOLDER=                 → yml-ts/ and yml-tc/ (default)
OUTPUT_FOLDER=profilesettings

# ============================================
# USAGE INSTRUCTIONS
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual Jira credentials
# 3. Set JIRA query parameters (version, cycle, folder)
# 4. Optional: Set OUTPUT_FOLDER for custom output directory
# 5. Run: npm run generate
#
# Examples:
#
# Profile & Settings:
#   JIRA_VERSION_NAME=Regression R5.2
#   JIRA_CYCLE_NAME=Feature R2
#   JIRA_FOLDER_NAME=Profile and Settings - Android
#   OUTPUT_FOLDER=profilesettings
#   npm run generate
#
# Transfer:
#   JIRA_VERSION_NAME=Sprint 10
#   JIRA_CYCLE_NAME=Regression Test
#   JIRA_FOLDER_NAME=Transfer - Android
#   OUTPUT_FOLDER=transfer
#   npm run generate
#
# Home (default output):
#   JIRA_VERSION_NAME=Sq Fraud Audit
#   JIRA_CYCLE_NAME=Acceptance Test
#   JIRA_FOLDER_NAME=Home - Android
#   OUTPUT_FOLDER=
#   npm run generate
