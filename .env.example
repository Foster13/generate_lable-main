# ============================================
# JIRA CREDENTIALS (WAJIB!)
# ============================================
JIRA_USERNAME = your_username
JIRA_PASSWORD = your_password
JIRA_BASE_URL = https://jira.bni.co.id

# ============================================
# MODE 1: FOLDER-BASED GENERATION
# Command: npm run generate
# Query: fixVersion = "X" AND cycleName in ("Y") AND folderName in ("Z")
# ============================================
JIRA_VERSION_NAME = Regression R5.2
JIRA_CYCLE_NAME = Feature R2
JIRA_FOLDER_NAME = Profile and Settings - Android
OUTPUT_FOLDER = profilesettings

# ============================================
# MODE 2: ASSIGNEE-ONLY GENERATION
# Command: npm run generate-assignee
# Query: assignee = "X" AND executionStatus = "Y"
# ============================================
JIRA_ASSIGNEE = your.username
JIRA_EXECUTION_STATUS = UNEXECUTED
OUTPUT_FOLDER_ASSIGNEE = all-my-tests

# ============================================
# USAGE INSTRUCTIONS
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual JIRA credentials (WAJIB!)
# 3. Choose generation mode:
#
# MODE 1 - Generate by Folder (all assignees in that folder):
#   - Update: JIRA_VERSION_NAME, JIRA_CYCLE_NAME, JIRA_FOLDER_NAME, OUTPUT_FOLDER
#   - Run: npm run generate
#   - Output: {OUTPUT_FOLDER}/yml-ts/ and {OUTPUT_FOLDER}/yml-tc/
#
# MODE 2 - Generate by Assignee (all folders for that user):
#   - Update: JIRA_ASSIGNEE, JIRA_EXECUTION_STATUS, OUTPUT_FOLDER_ASSIGNEE
#   - Run: npm run generate-assignee
#   - Output: {OUTPUT_FOLDER_ASSIGNEE}/yml-ts/ and {OUTPUT_FOLDER_ASSIGNEE}/yml-tc/
#
# ============================================
# EXAMPLES
# ============================================
#
# Example 1: Generate Spesifik Handling feature (Mode 1)
#   JIRA_VERSION_NAME = Sq Fraud Audit
#   JIRA_CYCLE_NAME = Acceptance Test
#   JIRA_FOLDER_NAME = Spesifik Handling - Android
#   OUTPUT_FOLDER = spesifik-handling
#   → Run: npm run generate
#
# Example 2: Generate all UNEXECUTED tests for user (Mode 2)
#   JIRA_ASSIGNEE = Muhamad.Irkhamsyah
#   JIRA_EXECUTION_STATUS = UNEXECUTED
#   OUTPUT_FOLDER_ASSIGNEE = all-my-tests
#   → Run: npm run generate-assignee