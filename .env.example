# ============================================
# JIRA CREDENTIALS
# ============================================
JIRA_USERNAME=your_username
JIRA_PASSWORD=your_password
JIRA_BASE_URL=https://jira.bni.co.id
JIRA_VERSION_NAME=Sq Fraud Audit
JIRA_CYCLE_NAME=Acceptance Test
JIRA_PAGINATION=1

# ============================================
# GENERATION MODE
# ============================================

# Single Label Mode (npm run generate)
JIRA_LABELS=TS_POJK_CASA_02

# Folder Mode (npm run generate-folder)
JIRA_FOLDER_NAME=CASA - Android

# ============================================
# LEGACY (Not used)
# ============================================
FILE_LOCATION=

# ============================================
# USAGE INSTRUCTIONS
# ============================================
# 1. Copy this file to .env
# 2. Fill in your actual Jira credentials
# 3. Choose generation mode:
#    - For single label: set JIRA_LABELS and run "npm run generate"
#    - For entire folder: set JIRA_FOLDER_NAME and run "npm run generate-folder"
# 4. Run the appropriate command
#
# Examples:
# Single: JIRA_LABELS=TS_POJK_CASA_02 → npm run generate
# Folder: JIRA_FOLDER_NAME=CASA - Android → npm run generate-folder